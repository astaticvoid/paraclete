{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "git": {
      "type": "local",
      "command": ["python3", "-m", "mcp_server_git", "--repository", "."],
      "enabled": true
    },
    "narsil": {
      "type": "local",
      "command": ["narsil-mcp", "--repos", ".", "--git", "--call-graph", "--preset", "balanced"],
      "enabled": true
    }
  }
}
